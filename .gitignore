# ========== Unity（任意子目录下都会匹配）==========
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emory[Cc]aptures/
[Rr]ecordings/

# 崩溃报告、缓存
sysinfo.txt
*.stacktrace
**/CrashReports/
**/AssetStoreTools*

# 自动生成的 VS / Rider 方案（Unity 会再生成）
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# ========== 编辑器 / IDE ==========
.vs/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ========== 操作系统 ==========
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# ========== 打包产物（体积大，勿提交）==========
*.apk
*.aab
*.ipa
*.app
*.exe
*.dmg
*.zip
*.unitypackage

# ========== 视频（体积大，勿进 Git；可放网盘 / Release / Git LFS）==========
*.mp4
*.mov
*.webm
*.mkv

# Visual Studio 2022+ 方案（与 *.sln 类似，Unity 可再生成）
*.slnx

# ========== 可选：若使用 Plastic SCM ==========
.plastic/

# ========== 可选：本地密钥 / 机器相关 ==========
*.keystore
*.jks
**/StreamingAssets/**/secrets*
